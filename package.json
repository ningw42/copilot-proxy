{
  "name": "@jer-y/copilot-proxy",
  "type": "module",
  "version": "0.7.8",
  "description": "Turn GitHub Copilot into an OpenAI/Anthropic-compatible server with Claude Code and Codex support.",
  "author": "jer-y",
  "homepage": "https://github.com/jer-y/copilot-proxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jer-y/copilot-proxy.git"
  },
  "bugs": "https://github.com/jer-y/copilot-proxy/issues",
  "keywords": [
    "proxy",
    "github-copilot",
    "openai-compatible"
  ],
  "bin": {
    "copilot-proxy": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "audit": "bun audit --ignore GHSA-3v7f-55p6-f55p --ignore GHSA-c2c7-rcm5-vvqj",
    "build": "tsdown",
    "dev": "bun run --watch ./src/main.ts start",
    "knip": "knip-bun",
    "lint": "eslint --cache",
    "lint:all": "eslint --cache .",
    "prepack": "npm run build",
    "prepare": "test -d .git && npx simple-git-hooks || true",
    "release": "bumpp && npm publish --access public",
    "start": "NODE_ENV=production bun run ./src/main.ts start",
    "test:live:copilot": "bun test tests/live/copilot-capabilities.test.ts",
    "typecheck": "tsc"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "clipboardy": "^5.3.1",
    "consola": "^3.4.2",
    "fetch-event-stream": "^0.1.6",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.18",
    "proxy-from-env": "^2.1.0",
    "srvx": "^0.11.15",
    "tiny-invariant": "^1.3.3",
    "undici": "^8.2.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/bun": "^1.3.13",
    "@types/proxy-from-env": "^1.0.4",
    "bumpp": "^11.1.0",
    "eslint": "^10.3.0",
    "knip": "^6.12.2",
    "lint-staged": "^17.0.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "yaml": "^2.8.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "bun run lint --fix"
  }
}
